# ENV Variables — MKG.VN (mkg.vn)
# Copy file này thành .env.local và điền giá trị thực

# ===== AI CHATBOT (chọn 1 trong 2) =====
# Google Gemini API (khuyên dùng — miễn phí có quota)
# Lấy tại: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# HOẶC OpenRouter API
# Lấy tại: https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_api_key_here

# ===== N8N WEBHOOK (nhận lead → Telegram) =====
# Tạo workflow n8n:
#   1. Trigger: Webhook (POST)
#   2. Node: Telegram Bot → send message {{ $json.message }}
#   3. Copy webhook URL vào đây
N8N_WEBHOOK_URL=https://your-n8n-instance.domain/webhook/mkg-lead

# ===== NEXT.JS =====
NEXT_PUBLIC_SITE_URL=https://mkg.vn
