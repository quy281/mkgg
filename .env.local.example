# =============================================
# MKG.VN — Environment Variables
# =============================================
# Sao chép file này thành .env.local và điền giá trị
# KHÔNG commit .env.local lên GitHub!

# ── KEYSTATIC (GitHub OAuth) ──────────────────
# Tạo tại: github.com/settings/developers → OAuth Apps → New OAuth App
# Homepage URL: https://mkg.vn
# Callback URL: https://mkg.vn/api/keystatic/github/oauth/callback
KEYSTATIC_GITHUB_CLIENT_ID=
KEYSTATIC_GITHUB_CLIENT_SECRET=
# Random string bất kỳ, min 32 ký tự (dùng: openssl rand -hex 32)
KEYSTATIC_SECRET=

# ── GITHUB REPO (để Keystatic đọc/ghi content) ─
# Tên GitHub username của bạn
NEXT_PUBLIC_GITHUB_OWNER=your-github-username
# Tên repo (vd: mkgvn)
NEXT_PUBLIC_GITHUB_REPO=mkgvn

# ── CLOUDFLARE R2 (lưu ảnh) ──────────────────
# Lấy tại: Cloudflare Dashboard → R2 → Manage R2 API Tokens
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=mkg-images
# URL public của bucket (enable trong R2 → bucket → Settings → Public Access)
R2_PUBLIC_URL=https://pub-xxxxxxxxxx.r2.dev
